general {
    colors = true
    interval = 5
    color_good = "#ffffff"
    color_bad = "#ff5555"
    color_degraded = "#aaaaaa"
}

order += "tztime local"
order += "battery all"

tztime local {
    format = "%Y-%m-%d | %H:%M"
}

battery all {
    format = "BAT %status %percentage"
    format_down = "No Battery"
    status_chr = "⚡"
    status_bat = ""
    status_full = "FULL"
    low_threshold = 15
}
